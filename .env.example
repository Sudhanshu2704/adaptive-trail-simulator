# === App Configuration ===
# Comma-separated list of allowed CORS origins
# Example: http://localhost:5173,https://yourusername.github.io
ALLOWED_ORIGINS=http://localhost:5173

# === Database Configuration ===
# Connection string for PostgreSQL
# For local dev via Docker: postgresql://admin:localpassword@db:5432/clinical_trials
# For production via Supabase, get this from your project dashboard
DATABASE_URL=postgresql://admin:localpassword@db:5432/clinical_trials

# === LLM Configuration ===
# Choose between 'ollama' (local) and 'groq' (cloud)
LLM_PROVIDER=ollama

# If using Ollama:
# Docker network URL to the ollama container
OLLAMA_BASE_URL=http://ollama:11434

# If using Groq:
# Get your free key from https://console.groq.com/keys
# GROQ_API_KEY=gsk_your_api_key_here

# === Frontend Configuration ===
# Add this to frontend/.env for local development or set in your deployment environment
# VITE_API_URL=http://localhost:8000
